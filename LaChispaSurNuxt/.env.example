# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno para Nuxt 3 — La Chispa Sur
# Copia este archivo como .env y rellena los valores
# ─────────────────────────────────────────────────────────────────────────────

# ── Server-only (Admin SDK) — NUNCA exponer al cliente ────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Pegar la clave privada completa con \n literales (el código reemplaza \\n → \n)
FIREBASE_PRIVATE_KEY=

# ── Públicas (prefijo NUXT_PUBLIC_) — Se embeben en el bundle del cliente ──────
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=
NUXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
