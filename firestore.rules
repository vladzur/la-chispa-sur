rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers de rol ──────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isEditor() {
      return request.auth != null && request.auth.token.editor == true;
    }

    function isApproved() {
      return isAdmin() || isEditor();
    }

    // Verifica que la escritura solo modifica kudosCount y que el valor sube
    function isKudosOnlyUpdate() {
      let incoming = request.resource.data;
      let existing = resource.data;
      return incoming.diff(existing).affectedKeys().hasOnly(['kudosCount'])
          && incoming.kudosCount > existing.get('kudosCount', 0);
    }

    // ── Posts ────────────────────────────────────────────────────────────────
    match /posts/{postId} {
      // Cualquier persona puede leer las noticias publicadas
      allow read: if true;

      // Crear: admin o editor aprobado
      allow create: if isApproved();

      // Eliminar: solo admin
      allow delete: if isAdmin();

      // Actualizar: admin puede todo; editor solo sus propios posts (excepto campos protegidos);
      // anónimos SOLO pueden incrementar kudosCount
      allow update: if isAdmin()
                    || (isEditor() && resource.data.authorId == request.auth.uid
                        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['authorId', 'createdAt']))
                    || isKudosOnlyUpdate();
    }

    // ── Usuarios ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Un usuario autenticado puede leer su propio documento
      allow read: if request.auth != null && request.auth.uid == userId;

      // Admin puede leer cualquier usuario (para el dashboard de editores)
      allow read: if isAdmin();

      // Un usuario puede crear su propio documento SOLO con role: 'pending'
      // (durante el registro desde un enlace de invitación válido)
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.role == 'pending'
                    && request.resource.data.keys().hasAll(['role', 'name', 'email', 'createdAt']);

      // Solo el admin puede modificar roles (aprobación/rechazo via Cloud Function)
      allow update, delete: if false;
    }

    // ── Tokens de invitación ─────────────────────────────────────────────────
    match /inviteTokens/{token} {
      // Lectura pública: front-end valida si el token existe y es válido
      allow read: if true;

      // Solo admin puede crear tokens de invitación
      allow create: if isAdmin();

      // Marcar como usado: solo el usuario autenticado que se está registrando
      // (actualización parcial: solo puede cambiar el campo 'used' a true y agregar 'usedBy')
      allow update: if request.auth != null
                    && resource.data.used == false
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used', 'usedBy', 'usedAt'])
                    && request.resource.data.used == true;

      // Nadie puede eliminar tokens desde el cliente
      allow delete: if false;
    }

    // ── Denegación por defecto ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
